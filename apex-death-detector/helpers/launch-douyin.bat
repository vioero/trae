@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

REM Apex Death Detector - 启动抖音
REM 支持传入路径参数，检测是否已运行

set "DOUYIN_PATH=%~1"

REM 如果没有传入路径，从注册表获取
if "%DOUYIN_PATH%"=="" (
    reg query "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\douyin.exe" /ve 2>nul | find "douyin.exe" >nul
    if !errorlevel!==0 (
        for /f "tokens=2,* delims=:" %%a in ('reg query "HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\douyin.exe" /ve 2^>nul ^| find "REG_"') do (
            set "DOUYIN_PATH=%%a"
            set "DOUYIN_PATH=!DOUYIN_PATH:~1!"
        )
    ) else (
        REM 尝试常见路径
        if exist "%ProgramFiles%\douyin\douyin.exe" set "DOUYIN_PATH=%ProgramFiles%\douyin\douyin.exe"
        if exist "%LocalAppData%\douyin\douyin.exe" set "DOUYIN_PATH=%LocalAppData%\douyin\douyin.exe"
    )
)

REM 检查抖音是否已在运行
tasklist /FI "IMAGENAME eq douyin.exe" 2>nul | find /I "douyin.exe" >nul
if !errorlevel!==0 (
    REM 抖音已在运行，激活窗口
    powershell -Command "& {
        Add-Type @'
using System;
using System.Runtime.InteropServices;
public class Win32 {
    [DllImport(\"user32.dll\")]
    public static extern bool SetForegroundWindow(IntPtr hWnd);
    [DllImport(\"user32.dll\")]
    public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
}
'@
        $p = Get-Process douyin -ErrorAction SilentlyContinue
        if ($p) {
            [Win32]::ShowWindow($p.MainWindowHandle, 9)
            [Win32]::SetForegroundWindow($p.MainWindowHandle)
        }
    }"
    echo 抖音窗口已激活
    exit /b 0
)

REM 如果有路径，启动抖音
if not "%DOUYIN_PATH%"=="" (
    if exist "%DOUYIN_PATH%" (
        start "" "%DOUYIN_PATH%"
        echo 抖音已启动: %DOUYIN_PATH%
        exit /b 0
    )
)

